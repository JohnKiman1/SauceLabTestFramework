{
  "name": "sourcedemoframework",
  "version": "1.0.0",
  "description": "Simple but enhanced test automation framework",
  "main": "index.js",
  "scripts": {
    "test": "pnpm exec playwright test",
    "test:smoke": "pnpm exec playwright test --grep '@smoke'",
    "test:regression": "pnpm exec playwright test --grep '@regression'",
    "test:negative": "pnpm exec playwright test --grep '@negative'",
    "test:edge": "pnpm exec playwright test --grep '@edge'",
    "test:happy": "pnpm exec playwright test --grep '@happy-path'",
    "test:ci": "pnpm exec playwright test --workers=1",
    "test:ui": "pnpm exec playwright test --ui",
    "test:headed": "pnpm exec playwright test --headed",
    "test:debug": "pnpm exec playwright test --debug",
    "test:chrome": "pnpm exec playwright test --project=chromium",
    "test:firefox": "pnpm exec playwright test --project=firefox",
    "test:webkit": "pnpm exec playwright test --project=webkit",
    "report:allure": "allure generate allure-results --clean -o allure-report",
    "report:serve": "allure serve allure-results",
    "report:html": "pnpm exec playwright show-report reports/ui/html-report",
    "ci:auth": "pnpm exec playwright test --project=chromium --grep '@smoke' --workers=1",
    "install:playwright": "pnpm exec playwright install --with-deps chromium"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "allure-playwright": "^3.10.0"
  }
}