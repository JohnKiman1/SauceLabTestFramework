{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@fixtures/*": ["ui/fixtures/*"],
      "@pages/*": ["ui/pages/*"],
      "@utils/*": ["utils/*"],
      "@tests/*": ["ui/tests/*"]
    }
  },
  "include": ["src/ui/**/*.ts", "src/utils/**/*.ts"],
  "exclude": ["node_modules", "dist", "reports", "src/load/**/*"]
}